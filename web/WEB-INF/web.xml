<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_0.xsd"
         version="3.0">

    <display-name>Blood Bank Management System</display-name>

    <!-- ================= LOGIN ================= -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <!-- ================= REGISTER ================= -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>    <!-- ================= ADMIN APPROVAL ================= -->
    <servlet>
        <servlet-name>AdminApprovalServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.AdminApprovalServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminApprovalServlet</servlet-name>
        <url-pattern>/AdminApprovalServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminUserManagementServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.AdminUserManagementServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUserManagementServlet</servlet-name>
        <url-pattern>/AdminUserManagementServlet</url-pattern>
    </servlet-mapping>

    <!-- ================= CERTIFICATE ================= -->
    <servlet>
        <servlet-name>DonationCertificateServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.DonationCertificateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DonationCertificateServlet</servlet-name>
        <url-pattern>/certificate</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>VerifyCertificateServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.VerifyCertificateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>VerifyCertificateServlet</servlet-name>
        <url-pattern>/verify-certificate</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CertificateQrServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.CertificateQrServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CertificateQrServlet</servlet-name>
        <url-pattern>/certificate-qr</url-pattern>
    </servlet-mapping>

    <!-- ================= EMERGENCY ================= -->
    <servlet>
        <servlet-name>EmergencyNotificationServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.EmergencyNotificationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EmergencyNotificationServlet</servlet-name>
        <url-pattern>/api/emergency-broadcast</url-pattern>
    </servlet-mapping>

    <!-- ================= LOCATOR ================= -->
    <servlet>
        <servlet-name>BloodBankLocatorServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.BloodBankLocatorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BloodBankLocatorServlet</servlet-name>
        <url-pattern>/api/locator</url-pattern>
    </servlet-mapping>

    <!-- ================= ANALYTICS ================= -->
    <servlet>
        <servlet-name>AnalyticsServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.AnalyticsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AnalyticsServlet</servlet-name>
        <url-pattern>/api/analytics</url-pattern>
    </servlet-mapping>

    <!-- SetupServlet removed - class not found in source -->

    <!-- ================= AUTH & DEVICES ================= -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.ResetPasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResetPasswordServlet</servlet-name>
        <url-pattern>/ResetPasswordServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterDeviceServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.RegisterDeviceServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterDeviceServlet</servlet-name>
        <url-pattern>/api/register-device</url-pattern>
    </servlet-mapping>

    <!-- ================= COMMUNITY FEATURES ================= -->
    <servlet>
        <servlet-name>BloodRequestServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.BloodRequestServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BloodRequestServlet</servlet-name>
        <url-pattern>/api/blood-request</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DonorLocatorServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.DonorLocatorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DonorLocatorServlet</servlet-name>
        <url-pattern>/api/donors</url-pattern>
    </servlet-mapping>

    <!-- ================= EXPORT REPORT ================= -->
    <servlet>
        <servlet-name>ExportReportServlet</servlet-name>
        <servlet-class>com.bloodbank.servlets.ExportReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ExportReportServlet</servlet-name>
        <url-pattern>/ExportReport</url-pattern>
    </servlet-mapping>

    <!-- ================= WELCOME ================= -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>
